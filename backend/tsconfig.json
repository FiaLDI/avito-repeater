{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "rootDir": "./",
    "outDir": "./dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["jest", "node"],

    "sourceMap": true,
    "incremental": true,

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,

    "paths": {
      "@app/*": ["./src/*"]
    }
  }
}
